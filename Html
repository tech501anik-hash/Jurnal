<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎴 Trade Journal</title>
    <link rel="manifest" href="manifest.json">
    <link rel="stylesheet" href="style.css">
    <meta name="theme-color" content="#120a1f">
</head>
<body>
    <header>
        <div class="title-area">
            <h1>🎴 Swing Journal</h1>
            <span id="network-status" class="online">Online</span>
        </div>
        <div class="stats">
            <div class="stat-box">Win Rate: <span id="winRate">0%</span></div>
            <div class="stat-box">Total PnL: $<span id="totalPnl">0.00</span></div>
        </div>
    </header>

    <main>
        <section class="trade-form">
            <h2>Log New Trade</h2>
            <form id="journalForm">
                <div class="input-group">
                    <input type="text" id="asset" placeholder="Asset (e.g., BTC/USDT)" required>
                    <select id="type">
                        <option value="Long">Long</option>
                        <option value="Short">Short</option>
                    </select>
                </div>
                <div class="input-group">
                    <input type="number" step="any" id="entry" placeholder="Entry Price" required>
                    <input type="number" step="any" id="exit" placeholder="Exit Price" required>
                    <input type="number" step="any" id="size" placeholder="Position Size (Qty)" required>
                </div>
                <input type="text" id="notes" placeholder="Technical analysis / setup notes...">
                <button type="submit">Save Trade Locally</button>
            </form>
        </section>

        <section class="trade-history">
            <h2>Recent Trades (Stored on Device)</h2>
            <div class="table-container">
                <table id="tradeTable">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Asset</th>
                            <th>Type</th>
                            <th>Entry</th>
                            <th>Exit</th>
                            <th>PnL</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="tradeBody">
                        </tbody>
                </table>
            </div>
        </section>
    </main>

    <script src="app.js"></script>
</body>
</html>

